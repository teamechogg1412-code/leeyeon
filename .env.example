# Neon / Postgres (Vercel)
# Pooled Neon URL works for both app + migrations on small projects.
# Local Docker (docker compose up -d):
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fanstage?schema=public"
DATABASE_URL="postgresql://USER:PASSWORD@HOST/db?sslmode=require"

# Auth.js / NextAuth
AUTH_SECRET="replace-with-a-long-random-string"
# AUTH_URL is set automatically on Vercel; set locally if needed:
# AUTH_URL="http://localhost:3000"

# Toss Payments (optional — without these, demo payment is used)
NEXT_PUBLIC_TOSS_CLIENT_KEY=""
TOSS_SECRET_KEY=""

# Vercel Blob (recommended on Vercel — keeps uploads durable)
# Create via Vercel → Storage → Blob, then copy the token here / into Vercel env.
# Without this token, local `npm run dev` still saves to public/uploads/.
BLOB_READ_WRITE_TOKEN=""

# Vercel Cron auth for /api/cron/schedule-reminders
# Set the same value in Vercel Project → Settings → Environment Variables
CRON_SECRET="replace-with-a-long-random-string"

# Web Push (optional) — generate with: npx web-push generate-vapid-keys
# Put both keys in local .env and Vercel env. Public key is safe to expose.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:owner@fanstage.app"
